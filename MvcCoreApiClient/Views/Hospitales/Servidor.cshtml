@model IEnumerable<MvcCoreApiClient.Models.Hospital>

@{
    ViewData["Title"] = "Servidor";
}

<h1>Servidor</h1>


<table class="table table-warning">
    <thead>
        <tr>
            <th>
                IdHospital
            </th>
            <th>
                Nombre


            </th>
            <th>
                Direccion
            </th>
            <th>
                Telefono
            </th>
            <th>
                Camas
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.idHospital)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Direccion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telefono)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Camas)
            </td>
            <td>
                <a asp-controller="Hospitales" asp-action="Details" asp-route-id="@item.idHospital">Details</a>
            </td>
        </tr>
}
    </tbody>
</table>
